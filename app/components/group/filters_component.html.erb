<div class="relative w-full my-6">
   <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-10 bg-linear-to-r from-black to-transparent md:hidden"></div>
   <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-10 bg-linear-to-l from-black to-transparent md:hidden"></div>

   <div class="w-full overflow-x-auto px-6 pb-2 scroll-x-hidden snap-x snap-mandatory md:overflow-x-visible md:px-0 md:pb-0">
      <ul
         id="<%= model_name.pluralize %>-filter"
         class="inline-flex min-w-max flex-nowrap justify-start gap-2 md:flex md:min-w-0 md:w-full md:flex-wrap md:justify-center md:gap-3"
      >
         <% attributes.each do |filter| %>
            <li class="shrink-0 snap-center">
               <%= helpers.active_link_to filter[:name].capitalize,
                  filter[:path],
                  id: filter[:id],
                  class: "glass-panel px-4 py-2 rounded-full text-[9px] font-bold uppercase tracking-widest md:px-6 md:py-2.5 md:text-[10px]",
                  class_active: "bg-accent/10 border-accent text-content",
                  class_inactive: "border-content/10 text-content/40 hover:text-content",
                  active: :exact %>
            </li>
         <% end %>
      </ul>
   </div>
</div>