<header class="mb-12 flex flex-col justify-between gap-6 md:flex-row md:items-end">
   <div class="flex flex-col gap-2">
      <h1 class="text-4xl font-black uppercase tracking-tighter text-white">
         <%= title %>
      </h1>

      <p class="font-mono text-xs uppercase tracking-[0.3em] text-white/30">
         Last synchronized <%= rand(1..60) %> min ago • Cluster node: SA-EAST-1
      </p>
   </div>

   <% if @path.present? %>
      <%= link_to path,
         class: 'btn-primary inline-flex w-fit items-center gap-2 rounded-xl px-4 py-2 text-[10px] font-black uppercase tracking-widest' do %>
         <i class="<%= icon %>" aria-hidden="true"></i>
         <span><%= label %></span>
      <% end %>
   <% end %>
</header>