<div class="mb-32" data-controller="carousel">
   <div class="mb-12 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-4">
         <span class="font-mono text-[10px] uppercase tracking-[0.5em] text-primary">
            <%= label %>
         </span>

         <h3 class="text-4xl font-black uppercase tracking-tighter text-content md:text-5xl">
            <%= title %>
         </h3>
      </div>

      <div class="flex gap-4">
         <button
            type="button"
            aria-label="Previous slide"
            data-carousel-target="prevButton"
            data-action="click->carousel#prev"
            class="glass-panel flex h-12 w-12 items-center justify-center rounded-full text-content/40 transition-colors hover:bg-accent hover:text-content"
            >
            <i class="fa-solid fa-arrow-left text-lg"></i>
         </button>

         <button
            type="button"
            aria-label="Next slide"
            data-carousel-target="nextButton"
            data-action="click->carousel#next"
            class="glass-panel flex h-12 w-12 items-center justify-center rounded-full text-content/40 transition-colors hover:bg-accent hover:text-content"
            >
            <i class="fa-solid fa-arrow-right text-lg"></i>
         </button>
      </div>
   </div>

   <div class="overflow-hidden pb-4" data-carousel-target="viewport">
      <div class="flex gap-6 transition-transform duration-500 ease-out" data-carousel-target="track">
         <%= render_items %>
      </div>
   </div>
</div>