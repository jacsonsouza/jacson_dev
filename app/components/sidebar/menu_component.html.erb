<div data-controller="sidebar">
   <aside class="z-20 flex min-h-dvh w-72 flex-col border-r border-content/10 bg-canvas">
      <header class="flex items-center gap-4 px-6 py-8">
         <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-content/10 bg-content/5">
            <%= image_tag 'logos/primary-logo.png',
               alt: 'Logo',
               class: 'h-8 w-8 object-contain',
               loading: 'eager' %>
         </div>

         <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-content">
               <%= current_user&.first_name.presence || 'User' %>
            </p>
            <span class="text-[11px] font-mono uppercase tracking-[0.2em] text-content/60">
               Control Center
            </span>
         </div>
      </header>

      <nav class="flex-1 px-4" aria-label="Sections">
         <ul class="space-y-1">
            <% sections.each do |section| %>
               <li>
                  <%= helpers.active_link_to section[:path],
                        class: 'flex w-full items-center gap-3 rounded-lg p-4 text-sm font-medium tracking-wide',
                        class_active: 'border-accent bg-accent/10 text-accent border-r-4 border-accent',
                        class_inactive: 'text-content/60 hover:bg-content/5 hover:text-content',
                        active: :exclusive do %>

                     <i class="<%= section[:icon] %> text-base" aria-hidden="true"></i>
                     <span class="uppercase"><%= section[:name] %></span>
                  <% end %>
               </li>
            <% end %>
         </ul>
      </nav>

      <div class="px-4 pb-6">
         <span class="mb-4 block h-px w-full bg-content/10"></span>

         <%= link_to destroy_user_session_path,
               data: { turbo_method: :delete },
               class: 'inline-flex w-full items-center justify-center gap-3 rounded-lg border border-content/10 bg-content/5 px-4 py-3 text-sm font-semibold tracking-wide text-content/70 transition-colors duration-150 hover:border-red-500 hover:bg-red-500/10 hover:text-red-600' do %>
            <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
            <span>Secure Logout</span>
         <% end %>
      </div>
   </aside>
</div>