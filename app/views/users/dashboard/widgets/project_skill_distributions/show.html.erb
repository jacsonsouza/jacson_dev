<%= turbo_frame_tag "project_skill_distribution" do %>
   <header class="mb-4">
      <div class="flex flex-col">
         <h3 
            id="project_skill_distribution_title"
            class="text-xl font-black text-white uppercase tracking-tight"
         >
            <%= t('.title') %>
         </h3>

         <span
            id="project_skill_distribution_subtitle"
            class="text-[10px] font-mono text-white/20 uppercase tracking-widest"
         >
            <%= t('.subtitle') %>
         </span>
      </div>
   </header>

   <%= pie_chart @project_skill_distribution, id: "project_skill_distribution_chart" %>
<% end %>
