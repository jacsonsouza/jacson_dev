<%= turbo_frame_tag "projects_chart", class: "block w-full min-w-0" do %>
   <header class="mb-4">
      <div class="flex flex-col">
         <h3 class="text-xl font-black text-white uppercase tracking-tight">
            Projects by skill
         </h3>

         <span class="text-[10px] font-mono text-white/20 uppercase tracking-widest">
            Skill distribution
         </span>
      </div>
   </header>

   <%= pie_chart @skill_distribution, id: 'projects_by_skill' %>
<% end %>