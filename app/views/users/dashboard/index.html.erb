<% provide(:page_title, t('.title') ) %>

<% count_charts = [
   { title: 'Total Projects', count: Project.count, icon: 'fa-project-diagram' },
   { title: 'Tech Arsenal', count: Skill.count, icon: 'fa-code' },
   { title: 'Inquiries', count: Message.count, icon: 'fa-envelope' },
   { title: 'Global Views', count: Ahoy::Visit.count, icon: 'fa-globe' }
]%>

<section class="space-y-8">
   <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <%= render partial: 'users/dashboard/partials/chart', collection: count_charts, as: :chart %>
   </div>

   <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="flex flex-col justify-center glass-panel min-h-56 w-full rounded-3xl p-8">
         <%= turbo_frame_tag 'views_chart', src: users_dashboard_views_chart_path %>
      </div>

      <div class="flex flex-col justify-center glass-panel min-h-56 w-full rounded-3xl p-8">
         <%= turbo_frame_tag 'projects_chart', src: users_dashboard_projects_by_skill_path %>
      </div>
   </div>
</section>