<section class="glass-panel p-8 rounded-3xl flex flex-col group h-full transition-transform duration-300 hover:scale-105 hover:border-primary hover:bg-primary/10">
   <div class="flex justify-between items-start mb-8">
      <div class="w-12 h-12 glass-panel rounded-xl flex items-center justify-center border-content/10 group-hover:border-accent/30 transition-colors">
         <%= image_tag url_for(skill.icon), alt: skill.name, class: "object-contain" %>
      </div>
      <div class="px-3 py-1.5 glass-panel border-primary/20 text-primary text-[10px] font-mono font-bold tracking-tighter rounded-lg group-hover:bg-primary/10 transition-colors">
         <%= "#{skill.proficiency}%" %>
      </div>
   </div>

   <div class="flex-1">
      <h3 class="text-xl font-display font-black text-content mb-3 tracking-tight group-hover:text-primary transition-colors">
         <%= skill.name %>
      </h3>
      <p class="text-xs text-content/40 font-medium leading-relaxed">
         <%= skill.short_description %>
      </p>
   </div>

   <div class="mt-8 pt-6 border-t border-content/5 flex items-center justify-between">
      <span class="text-[9px] font-mono text-content/20 uppercase tracking-[0.2em]">
         <%= skill.category %>
      </span>
      <i class="fa-solid fa-arrow-up-right-from-square text-content/10 group-hover:text-primary transition-all transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"></i>
   </div>
</section>