<div id="projects" class="w-full flex flex-col mt-10">

   <div class="flex flex-col items-center gap-2 mb-10">
      <span class="text-[10px] font-mono tracking-[0.8em] text-white/30 uppercase">Selected Works</span>
      <h1 class="text-6xl md:text-8xl font-display font-black text-white leading-tight tracking-tighter flex items-center gap-6">
         <span>Projects</span>
         <div class="w-12 h-0.5 bg-primary"></div>
      </h1>
      <p class="text-sm md:text-base text-white/40 max-w-lg text-center font-medium leading-relaxed uppercase tracking-widest">
         Architecting scalable systems and experimental digital interfaces.
      </p>
   </div>

   <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 p-6">
      <%= render partial: 'home/partials/project', collection: @projects, as: :project %>
   </div>

</div>