<div class="max-w-7xl grid grid-cols-1 md:grid-cols-2 gap-28 py-20">
   <div class="flex flex-col gap-16 animate-reveal">
      <div class="space-y-6">
         <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-green-500"></span>
            <span class="text-[10px] font-mono tracking-[0.2em] text-content/40 uppercase">Available for opportunities</span>
         </div>
         <h1 class="text-6xl md:text-8xl font-display font-black text-content leading-none tracking-tighter uppercase">Get in <br>
            touch</h1>
         <p class="text-content/40 max-w-sm text-sm leading-relaxed">I'm currently looking for new projects and collaborations. Let's build something exceptional together.</p>
      </div>

      <div class="flex flex-col gap-1">
         <span class="text-[9px] font-mono text-content/20 uppercase tracking-[0.2em]">Local time / GMT-3</span>
         <span class="text-xs font-bold text-content/60 font-mono"><%= l(Time.now, format: '%I:%M %p') %></span>
      </div>
   </div>

   <%= render 'home/partials/contact_form' %>
</div>