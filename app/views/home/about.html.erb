<section
   class="w-full max-w-7xl p-6 mt-10"
   data-controller="ai-chat"
>
   <header class="mb-12 flex items-center gap-3 px-2">
      <h2 class="text-sm font-bold uppercase tracking-widest">
         <%= t('.title') %>
      </h2>

      <span class="h-1.5 w-1.5 rounded-full bg-green-500" aria-hidden="true"></span>
   </header>

   <div class="grid min-h-0 flex-1 grid-cols-1 gap-12 overflow-hidden pb-12 md:grid-cols-[1fr_300px] md:gap-24">
      <div id="ai-chat" class="flex max-h-[400px] flex-col overflow-hidden rounded-lg border border-content/10">
         <div
            id="chat-box"
            data-ai-chat-target="messages"
            class="chat-scroll min-h-0 flex-1 space-y-8 overflow-y-auto p-6 md:p-10"
            role="log"
            aria-live="polite"
         >
            <div class="msg-enter flex justify-start">
               <div class="max-w-[85%] rounded-2xl rounded-tl-none border border-content/5 px-5 py-3 text-sm leading-relaxed text-content/60">
                  <%= t('.presentation') %>
               </div>
            </div>
         </div>

         <div class="shrink-0 p-6 md:p-8">
            <form data-action="submit->ai-chat#submit" class="flex items-center gap-4">
               <input
                  type="text"
                  name="question"
                  data-ai-chat-target="input"
                  placeholder="<%= t('.ask') %>"
                  class="flex-1 border-b border-content/10 bg-transparent py-4 text-sm text-content placeholder:text-content/20 transition-colors focus:border-primary focus:outline-none"
               >

                  <button
                     type="submit"
                     data-ai-chat-target="submitButton"
                     class="p-2 text-content transition-colors hover:text-primary"
                  >
                     <i class="fa-solid fa-bolt" aria-hidden="true"></i>
                  </button>
               </form>

               <p class="mt-4 px-1 font-mono text-[9px] uppercase tracking-widest text-content/20">
                  <%= t('.execute') %>
               </p>
            </div>
         </div>

         <aside id="ai-operations" class="flex flex-col gap-10">
            <h3
               id="ai-operations-title"
               class="font-mono text-[10px] uppercase tracking-[0.4em] text-content/30"
            >
               <%= t('.operations') %>
            </h3>

            <nav class="flex flex-col" aria-label="AI operations">
               <% default_interactions.each do |interaction| %>
                  <button
                     type="button"
                     data-action="click->ai-chat#prefill"
                     data-question="<%= interaction[:question] %>"
                     class="group flex items-center gap-4 border-b border-content/10 py-5 text-content/40 transition-colors hover:border-primary hover:text-primary"
                     >
                     <i class="fa-solid <%= interaction[:icon] %>" aria-hidden="true"></i>
                     <span class="text-[10px] font-bold uppercase tracking-widest">
                        <%= interaction[:label] %>
                     </span>
                  </button>
               <% end %>
            </nav>

            <p class="mt-auto pb-4 font-mono text-[9px] uppercase leading-relaxed tracking-widest text-content/10">
               Architecture Intelligence V2.44
               <br>
               Production Grade Environment
            </p>
         </aside>
      </div>
   </div>
</section>