<header class="flex h-20 items-center justify-between gap-4 border-b border-white/10 px-10">
   <button
      type="button"
      data-controller="icon-toggle"
      data-icon-toggle-sidebar-outlet=".sidebar-container"
      data-action="click->icon-toggle#toggleSidebar"
      class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-xl text-content/40 transition-colors duration-150 hover:bg-content/5 hover:text-content"
      >
      <i
         data-icon-toggle-target="icon"
         class="fa-regular fa-square-caret-left text-2xl"
      ></i>
   </button>

   <div class="group inline-flex cursor-pointer items-center gap-4">
      <div class="flex flex-col items-end">
         <span class="text-xs font-bold uppercase tracking-widest text-content">
            <%= current_user&.first_name.presence || 'User' %>
         </span>

         <span class="font-mono text-[9px] uppercase tracking-[0.2em] text-content/60">
            Super User
         </span>
      </div>

      <div class="h-10 w-10 rounded-full border border-content/10 p-0.5 transition-colors duration-150 group-hover:border-primary">
         <%= image_tag 'default_pic.png',
            alt: "#{current_user&.first_name.presence || 'User'} avatar",
            class: 'h-full w-full rounded-full object-cover',
            loading: 'eager' %>
      </div>
   </div>
</header>