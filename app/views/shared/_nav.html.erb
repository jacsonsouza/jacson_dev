<nav id="menu" class="fixed hidden md:block top-6 left-1/2 z-50 -translate-x-1/2">
   <ul class="flex items-center gap-2 rounded-full border border-muted bg-surface/30 p-2 backdrop-blur-md">
      <% nav_items.each do |item| %>
         <li>
            <%= active_link_to item[:name], item[:path],
                              class: "block rounded-full px-4 py-2 text-[11px] uppercase tracking-[0.2em] transition-colors duration-300",
                              class_active: "bg-primary text-content font-semibold",
                              class_inactive: "text-content/30 hover:text-content/70",
                              active: :exclusive %>
         </li>
      <% end %>
   </ul>
</nav>
