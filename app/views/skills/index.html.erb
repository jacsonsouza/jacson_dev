<section class="w-full max-w-7xl px-2 md:px-4 mt-10">

   <div id="skills-header" class="flex flex-col items-center gap-2 mb-10">
      <span class="text-[10px] font-mono tracking-[0.8em] text-white/30 uppercase">
         <%= t('.selected') %>
      </span>

      <h1 class="text-6xl md:text-8xl flex items-center gap-6">
         <span><%= t('.title') %></span>
         <span class="w-12 h-0.5 bg-primary"></span>
      </h1>

      <p class="subheadline md:text-base max-w-lg text-center font-medium uppercase tracking-widest">
         <%= t('.subtitle') %>
      </p>

      <%= rc 'group/filters', model: Skill, filters: Skill.categories %>
   </div>

   <ul id="skills" class="responsive-grid">
      <%= render partial: 'skills/partials/skill', collection: @skills, as: :skill %>
   </ul>

</section>